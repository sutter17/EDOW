# ─── Cloudflare R2 ───────────────────────────────────────────
# Found in Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=images
R2_PUBLIC_URL=https://images.dcepiscopalfellowship.org

# ─── Partiful ────────────────────────────────────────────────
# Authenticate each account: npx partiful-cli auth login +1xxxxxxxxxx
# Then copy userId and refreshToken from ~/.config/partiful/auth.json
# Add as many accounts as needed — first entry is used by default
PARTIFUL_API_KEY=AIzaSyCky6PJ7cHRdBKk5X7gjuWERWaKWBHr4_k
PARTIFUL_ORG_USER_ID=TdAJl2k33LHLrWpyeNeC
PARTIFUL_ACCOUNTS=[{"name":"DCEF Org","userId":"TdAJl2k33LHLrWpyeNeC","refreshToken":""},{"name":"Your Name","userId":"","refreshToken":""}]

# ─── Google OAuth (admin.html) ────────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
